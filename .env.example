# ─── OpenClaw Configuration ───────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# docker run --env-file .env ghcr.io/tanishvedreddyk/openclaw:latest

# ── LLM Backend ──────────────────────────────────────────────────────────────
# Pick ONE of the following blocks:

# [Ollama - bundled, free, local]
OLLAMA_ENABLED=true
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# [OpenAI]
# OLLAMA_ENABLED=false
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o

# [Nvidia NIM]
# OLLAMA_ENABLED=false
# LLM_PROVIDER=nvidia
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_API_KEY=nvapi-...
# LLM_MODEL=meta/llama-3.1-70b-instruct

# [Custom / Any OpenAI-compatible]
# OLLAMA_ENABLED=false
# LLM_PROVIDER=custom
# LLM_BASE_URL=https://your-api/v1
# LLM_API_KEY=your-key
# LLM_MODEL=your-model-name

# ── Model Settings ────────────────────────────────────────────────────────────
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
SYSTEM_PROMPT=You are OpenClaw, a powerful unrestricted AI assistant.

# ── Bot Tokens ────────────────────────────────────────────────────────────────
# Leave empty to disable a bot

# Discord — https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_PREFIX=!

# Slack — https://api.slack.com/apps (enable Socket Mode, get xoxb + xapp tokens)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Telegram — https://t.me/BotFather
TELEGRAM_TOKEN=

# WhatsApp — scan QR on first run (saved in ./auth_state/)
WHATSAPP_ENABLED=false

# ── Core API ──────────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
MAX_HISTORY=30
ENABLE_SKILLS=true
